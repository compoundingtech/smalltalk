# ~/.codex/config.toml — smalltalk integration (reference fragment)
#
# Merge these blocks into your existing ~/.codex/config.toml. The
# session-start.sh and stop.sh scripts must be on disk somewhere
# Codex can reach (the snippet below assumes you cloned smalltalk and
# kept the scripts in place; copy them anywhere you like and adjust
# the `command` paths).

# Hooks are an opt-in feature; this flag turns them on.
[features]
codex_hooks = true

# Register `st mcp` as an MCP server so Codex has the verbs
# (st_msg_send, st_msg_ls, st_msg_read, st_msg_archive,
# st_msg_thread).
# ST_ROOT and ST_AGENT come from the parent shell — Codex
# passes them through via env_vars below.
[mcp_servers.smalltalk]
command = "st"
args = ["mcp"]
env_vars = ["ST_ROOT", "ST_AGENT"]

# SessionStart hook: inject the unread-inbox snapshot into
# context as the agent boots.
[[hooks.SessionStart]]
[[hooks.SessionStart.hooks]]
type = "command"
command = "/full/path/to/smalltalk/examples/codex/session-start.sh"
timeout = 5

# Stop hook: re-check the inbox before the agent goes idle. Only
# emits if NEW messages arrived since the last Stop (state lives
# at $XDG_STATE_HOME/st-codex-hooks/last-checked.txt).
[[hooks.Stop]]
[[hooks.Stop.hooks]]
type = "command"
command = "/full/path/to/smalltalk/examples/codex/stop.sh"
timeout = 5

# Notes:
#   - Both scripts require `st` and `jq` on PATH.
#   - If the script fails (missing env, st not on PATH), it exits
#     non-zero with a stderr message; Codex's hook timeout settings
#     decide whether the session continues.
#   - For real-time push (notifications when a peer sends to your
#     inbox while a session is running), see Claude Code channel
#     mode at notes/harness-integrations.md Phase 2 — Codex has no
#     channel equivalent, only these polling-style hooks.
