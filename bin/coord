#!/usr/bin/env bash
# coord — back-compat alias for `st`. brief-005-phase0.
#
# Existing `.mcp.json` files point at `bin/coord`; this file stays at
# the same path so they continue to resolve. It captures the invoked
# name ("coord") into the env var the node entry checks, then chains
# to the real `bin/st` shim. The next shim sees `_ST_INVOKED_AS`
# already set and keeps it.
#
# Phase 5 (much later, after every agent's config has migrated to
# `bin/st`) is when this alias gets dropped.

set -euo pipefail

export _ST_INVOKED_AS="${_ST_INVOKED_AS:-$(basename "$0")}"
exec "$(cd "$(dirname "$0")" && pwd)/st" "$@"
